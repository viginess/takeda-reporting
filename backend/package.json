{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend service for Clin Solutions L.L.C. project",
  "main": "src/app/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app/server.ts",
    "build": "tsc",
    "start": "node dist/app/server.js",
    "db:generate": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx --env-file=.env node_modules/drizzle-kit/bin.cjs push",
    "db:import-meddra": "tsx --env-file=.env src/scripts/import-meddra.ts",
    "db:generate-mock-meddra": "tsx --env-file=.env src/scripts/generate-mock-meddra.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@azure-rest/ai-translation-text": "^1.0.1",
    "@supabase/supabase-js": "^2.97.0",
    "@trpc/server": "^11.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pdfkit": "^0.17.5",
    "@xmldom/xmldom": "^0.8.11",
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "html-to-text": "^9.0.5",
    "imapflow": "^1.3.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.17.2",
    "pg": "^8.19.0",
    "xlsx": "^0.18.5",
    "xmlbuilder2": "^4.0.3",
    "xmllint-wasm": "^5.1.0",
    "xpath": "^0.0.34",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.19.37",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.10.9",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
