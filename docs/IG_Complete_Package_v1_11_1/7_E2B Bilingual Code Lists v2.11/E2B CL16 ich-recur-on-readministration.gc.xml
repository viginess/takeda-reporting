	<Identification>
		<ShortName>ich-recur-on-readministration</ShortName>
		<LongName>Did Reaction Recur on Re-administration?</LongName>
		<Version>2.0</Version>
		<CanonicalUri>2.16.840.1.113883.3.989.2.1.1.16</CanonicalUri>
		<CanonicalVersionUri>2.16.840.1.113883.3.989.2.1.1.16.2</CanonicalVersionUri>
		<Agency>
			<ShortName>E2B</ShortName>
			<LongName>Transmission of Individual Case Safety Reports</LongName>
		</Agency>
	</Identification>
	<ColumnSet>
	<Column Use="required" Id="code">
		<ShortName>numeric-code</ShortName>
		<Data Type="unsignedShort"></Data>
	</Column>
	<Column Use="optional" Id="en">
		<ShortName>english-label</ShortName>
		<Data Type="string" Lang="en"></Data>
	</Column>
	<Column Use="optional" Id="ja">
		<ShortName>japanese-label</ShortName>
		<Data Type="string" Lang="ja"/>
	</Column>
	<Column Use="optional" Id="cf">
		<ShortName>current flag</ShortName>
		<Data Type="string" Lang="en"/>
	</Column>
	</ColumnSet>
	<SimpleCodeList>
	<Row>
		<Value ColumnRef="code"><SimpleValue>1</SimpleValue></Value>
		<Value ColumnRef="en"><SimpleValue>YES -- YES (rechallenge was done, reaction recurred)</SimpleValue></Value>
		<Value ColumnRef="ja"><SimpleValue>はい - はい (再投与を行い、副作用が再発した)</SimpleValue></Value>
		<Value ColumnRef="cf"><SimpleValue>y</SimpleValue></Value>
	</Row>
	<Row>
		<Value ColumnRef="code"><SimpleValue>2</SimpleValue></Value>
		<Value ColumnRef="en"><SimpleValue>YES -- NO (rechallenge was done, reaction did not recur)</SimpleValue></Value>
		<Value ColumnRef="ja"><SimpleValue>はい - いいえ (再投与を行ったが、副作用は再発しなかった)</SimpleValue></Value>
		<Value ColumnRef="cf"><SimpleValue>y</SimpleValue></Value>
	</Row>
	<Row>
		<Value ColumnRef="code"><SimpleValue>3</SimpleValue></Value>
		<Value ColumnRef="en"><SimpleValue>YES -- UNK (rechallenge was done, outcome unknown)</SimpleValue></Value>
		<Value ColumnRef="ja"><SimpleValue>はい - 不明 (再投与を行ったが、転帰は不明)</SimpleValue></Value>
		<Value ColumnRef="cf"><SimpleValue>y</SimpleValue></Value>
	</Row>
	<Row>
		<Value ColumnRef="code"><SimpleValue>4</SimpleValue></Value>
		<Value ColumnRef="en"><SimpleValue>NO -- N/A (no rechallenge was done, recurrence is not applicable)</SimpleValue></Value>
		<Value ColumnRef="ja"><SimpleValue>いいえ - 該当なし (再投与は行わなかった、再発は該当せず)</SimpleValue></Value>
		<Value ColumnRef="cf"><SimpleValue>y</SimpleValue></Value>
	</Row>
	</SimpleCodeList>
