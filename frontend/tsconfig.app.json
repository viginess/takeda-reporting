{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client", "node", "pdfkit"],

    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "drizzle-orm/*": ["node_modules/drizzle-orm/*"],
      "drizzle-orm": ["node_modules/drizzle-orm"],
      "pg": ["node_modules/@types/pg", "node_modules/pg"],
      "zod": ["node_modules/zod"],
      "jsonwebtoken": ["node_modules/@types/jsonwebtoken", "node_modules/jsonwebtoken"],
      "@trpc/server": ["node_modules/@trpc/server"],
      "@trpc/server/*": ["node_modules/@trpc/server/*"],
      "@supabase/supabase-js": ["node_modules/@supabase/supabase-js"],
      "@supabase/supabase-js/*": ["node_modules/@supabase/supabase-js/*"],
      "axios": ["node_modules/axios"],
      "dotenv": ["node_modules/dotenv"],
      "adm-zip": ["node_modules/@types/adm-zip", "node_modules/adm-zip"],
      "pdfkit": ["node_modules/@types/pdfkit", "node_modules/pdfkit"],
      "xmlbuilder2": ["node_modules/xmlbuilder2"],
      "xmllint-wasm": ["node_modules/xmllint-wasm"],
      "@xmldom/xmldom": ["node_modules/@types/xmldom", "node_modules/@xmldom/xmldom"],
      "xpath": ["node_modules/xpath"],
      "nodemailer": ["node_modules/@types/nodemailer", "node_modules/nodemailer"],
      "imapflow": ["node_modules/imapflow"],
      "html-to-text": ["node_modules/@types/html-to-text", "node_modules/html-to-text"]
    }
  },
  "include": ["src"]
}